{
  "name": "forgetme",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop-first private evidence vault for traceable personal archives.",
  "author": "ForgetMe",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.{ts,tsx}\" \"scripts/**/*.{js,mjs}\" \"eslint.config.js\"",
    "lint:fix": "npm run lint -- --fix",
    "pack": "npm run build && node ./scripts/run-electron-builder.mjs --dir --config electron-builder.yml",
    "dist": "npm run build && node ./scripts/run-electron-builder.mjs --config electron-builder.yml",
    "release:doctor": "node ./scripts/check-release-env.mjs",
    "dist:release": "npm run build && node ./scripts/check-release-env.mjs --require-signing --require-notarization && node ./scripts/run-electron-builder.mjs --config electron-builder.yml",
    "preview": "electron-vite preview",
    "test:unit": "node ./scripts/run-vitest.mjs",
    "test:e2e": "npm run build && node ./scripts/run-playwright.mjs",
    "test:e2e:objective": "npm run test:e2e -- tests/e2e/objective-workbench-deliberation-flow.spec.ts tests/e2e/objective-workbench-external-verification-flow.spec.ts tests/e2e/objective-workbench-operator-confirmation-flow.spec.ts",
    "test:smoke:release": "npm run test:e2e -- tests/e2e/import-batch.spec.ts tests/e2e/person-review-flow.spec.ts tests/e2e/memory-workspace-flow.spec.ts tests/e2e/memory-workspace-approved-draft-hosted-share-link-flow.spec.ts",
    "verify:release": "npm run lint && npm run test:typecheck && npm run test:unit && npm run test:smoke:release && npm run pack",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "test:typecheck": "npm run typecheck:app && npm run typecheck:node"
  },
  "dependencies": {
    "exifreader": "^4.32.0",
    "mammoth": "^1.9.1",
    "pdf-parse": "^1.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.3.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^4.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.4.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
