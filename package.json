{
  "name": "forgetme",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test:unit": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:smoke:release": "npm run test:e2e -- tests/e2e/import-batch.spec.ts tests/e2e/person-review-flow.spec.ts tests/e2e/memory-workspace-flow.spec.ts tests/e2e/memory-workspace-approved-draft-hosted-share-link-flow.spec.ts",
    "verify:release": "npm run test:typecheck && npm run test:unit && npm run test:smoke:release && npm run build",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "test:typecheck": "npm run typecheck:app && npm run typecheck:node"
  },
  "dependencies": {
    "exifreader": "^4.32.0",
    "mammoth": "^1.9.1",
    "pdf-parse": "^1.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^37.3.1",
    "electron-vite": "^4.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vitest": "^3.2.4"
  }
}
